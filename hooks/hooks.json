{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${extensionPath}/hooks/scripts/validate-cloud-command.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${extensionPath}/hooks/scripts/validate-cloud-command.py\" --session-start gemini"
          }
        ]
      }
    ]
  }
}
