{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${extensionPath:-$CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-cloud-command.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${extensionPath:-$CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate-cloud-command.py\" --session-start claude"
          }
        ]
      }
    ]
  }
}
